generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          String         @default("agent")
  online         Boolean        @default(false)
  disabled       Boolean        @default(false)
  lastHeartbeat  DateTime?
  createdAt      DateTime       @default(now())
  failedAttempts Int            @default(0)
  lockedUntil    DateTime?
  conversations Conversation[]
  cannedResponses CannedResponse[]
  internalNotes  InternalNote[]
}

model Conversation {
  id           String    @id @default(cuid())
  visitorId    String
  visitorToken String?
  visitorName  String?
  visitorEmail String?
  topic        String?
  status       String    @default("open")
  priority     String    @default("normal")
  assignedToId String?
  assignedTo   Admin?    @relation(fields: [assignedToId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  firstResponseAt DateTime?
  messages     Message[]
  metadata     Json?
  tags         ConversationTag[] @relation("ConversationTags")
  internalNotes InternalNote[]
  csatRating   CSATRating?
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  senderType      String
  senderId        String?
  senderName      String?
  body            String
  fileUrl         String?
  read            Boolean      @default(false)
  replyToId       String?
  replyToBody     String?
  replyToSender   String?
  replyToFileUrl  String?
  reactions       Json?
  createdAt       DateTime     @default(now())
}

model FormSubmission {
  id        String   @id @default(cuid())
  type      String
  data      Json
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  tags      String[]
  metadata  Json?
  createdAt DateTime @default(now())
}

// ── CMS ──────────────────────────────────────────────────────────────────────

model BlogPost {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  excerpt   String
  category  String
  author    String   @default("CiroStack Team")
  date      String
  dateSort  DateTime
  readMin   Int      @default(5)
  imageUrl  String?
  featured  Boolean  @default(false)
  published Boolean  @default(false)
  tags      String[]
  body      String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id          String   @id @default(cuid())
  title       String
  department  String
  type        String   @default("Full-Time")
  location    String   @default("Remote")
  description String
  body        String?  @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PortfolioProject {
  id               String   @id @default(cuid())
  slug             String   @unique
  title            String
  client           String
  vertical         String
  category         String
  service          String
  country          String   @default("")
  location         String   @default("")
  size             String   @default("")
  duration         String   @default("")
  year             String   @default("")
  description      String
  aboutClient      String?  @db.Text
  challenge        String?  @db.Text
  solution         String?  @db.Text
  result           String?  @db.Text
  imageUrl         String?
  featured         Boolean  @default(false)
  published        Boolean  @default(true)
  keyFeatures      Json?
  metrics          Json?
  technologies     Json?
  process          Json?
  whatClientLoved   Json?
  challengesOvercome Json?
  testimonial      Json?
  relatedProjects  Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Event {
  id              String   @id @default(cuid())
  slug            String   @unique
  type            String   @default("Webinar")
  title           String
  description     String
  date            String
  time            String   @default("")
  location        String   @default("Online")
  attendees       Int      @default(0)
  featured        Boolean  @default(false)
  published       Boolean  @default(true)
  registrationUrl String?
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Resource {
  id          String   @id @default(cuid())
  slug        String   @unique
  type        String   @default("Guide")
  title       String
  description String
  pages       String   @default("")
  tags        String[]
  isNew       Boolean  @default(true)
  published   Boolean  @default(true)
  downloadUrl String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Announcement {
  id       String   @id @default(cuid())
  slug     String   @unique
  type     String   @default("Press Release")
  title    String
  summary  String
  body     String?  @db.Text
  date     String
  source   String?
  tag      String   @default("")
  featured Boolean  @default(false)
  published Boolean @default(true)
  url      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Newsroom ─────────────────────────────────────────────────────────────────

model NewsArticleBlocklist {
  id        String   @id @default(cuid())
  url       String   @unique
  title     String?
  deletedAt DateTime @default(now())
}

model NewsArticleScrapeAttempt {
  id          String   @id @default(cuid())
  url         String   @unique
  attempts    Int      @default(1)
  lastAttempt DateTime @default(now())
}

model NewsArticle {
  id            String   @id @default(cuid())
  url           String   @unique
  slug          String   @unique
  title         String
  description   String   @default("")
  content       String   @db.Text
  image         String?
  publishedAt   DateTime
  source        String
  sourceUrl     String?
  type          String
  hnPoints      Int?
  hnComments    Int?
  hnDiscussionUrl String?
  fetchedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ── Client Portal ─────────────────────────────────────────────────────────────

model Client {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  avatarUrl     String?
  company       String?
  otpCode       String?
  otpExpiry     DateTime?
  otpRequestCount Int     @default(0)
  otpRateLimitReset DateTime?
  createdAt     DateTime  @default(now())
  projects      Project[]
  invoices      Invoice[]
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  teamMembers   ClientTeamMember[]
  invoiceDisputes InvoiceDispute[]
}

model Project {
  id          String          @id @default(cuid())
  clientId    String
  client      Client          @relation(fields: [clientId], references: [id])
  title       String
  description String?
  status      String          @default("discovery")
  startDate   DateTime?
  dueDate     DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  milestones  Milestone[]
  updates     ProjectUpdate[]
  files       ProjectFile[]
  comments    ProjectComment[]
  invoices    Invoice[]
}

model Milestone {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  title       String
  dueDate     DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  authorId  String?
  body      String
  internal  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id])
  name       String
  url        String
  size       Int?
  uploadedBy String?
  createdAt  DateTime @default(now())
}

model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  clientId  String
  body      String
  createdAt DateTime @default(now())
}

model Invoice {
  id         String    @id @default(cuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id])
  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id])
  number     String    @unique
  amount     Int
  currency   String    @default("USD")
  usdRate    Float     @default(1) // exchange rate to USD at time of invoice creation
  status     String    @default("unpaid")
  dueDate    DateTime?
  paidAt     DateTime?
  paymentRef String?
  lineItems  Json
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  disputes   InvoiceDispute[]
}

// ── Push Notifications ────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  ownerType String
  ownerId   String
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  title     String
  body      String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── Canned Responses ─────────────────────────────────────────────────────────

model CannedResponse {
  id        String   @id @default(cuid())
  adminId   String?
  admin     Admin?   @relation(fields: [adminId], references: [id])
  title     String
  shortcut  String?
  content   String   @db.Text
  category  String   @default("General")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Conversation Tags ────────────────────────────────────────────────────────

model ConversationTag {
  id            String         @id @default(cuid())
  name          String         @unique
  color         String         @default("#6366f1")
  conversations Conversation[] @relation("ConversationTags")
  createdAt     DateTime       @default(now())
}

// ── Business Hours & Widget Config ───────────────────────────────────────────

model BusinessHours {
  id        String  @id @default(cuid())
  day       Int     // 0=Sunday, 6=Saturday
  startTime String  // "09:00"
  endTime   String  // "17:00"
  enabled   Boolean @default(true)
  timezone  String  @default("UTC")
}

model WidgetConfig {
  id              String  @id @default(cuid())
  primaryColor    String  @default("#6366f1")
  position        String  @default("bottom-right")
  welcomeMessage  String  @default("Hi! How can we help you?")
  offlineMessage  String  @default("We're currently offline. Leave a message and we'll get back to you.")
  preChatForm     Boolean @default(false)
  preChatFields   Json?   // [{name, label, type, required}]
  showBranding    Boolean @default(true)
  autoOpenDelay   Int?    // ms before auto-open, null = never
  updatedAt       DateTime @updatedAt
}

// ── Assignment Rules ─────────────────────────────────────────────────────────

model AssignmentRule {
  id        String   @id @default(cuid())
  name      String
  type      String   // "round-robin" | "topic-based" | "load-balance"
  criteria  Json?    // {topics: [...], maxLoad: N}
  adminIds  String[] // target admin IDs
  enabled   Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
}

// ── Automation Rules ─────────────────────────────────────────────────────────

model AutomationRule {
  id        String   @id @default(cuid())
  name      String
  trigger   String   // "new-conversation" | "offline" | "keyword" | "no-response"
  conditions Json?   // {keywords: [...], delayMinutes: N}
  action    String   // "send-message" | "assign" | "tag" | "close"
  actionData Json    // {message: "...", adminId: "...", tagId: "..."}
  enabled   Boolean  @default(true)
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Internal Notes ───────────────────────────────────────────────────────────

model InternalNote {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  adminId        String
  admin          Admin        @relation(fields: [adminId], references: [id])
  body           String       @db.Text
  createdAt      DateTime     @default(now())
}

// ── Knowledge Base ───────────────────────────────────────────────────────────

model KnowledgeArticle {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String   @db.Text
  category  String   @default("General")
  published Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── SLA Configuration ────────────────────────────────────────────────────────

model SLAConfig {
  id                    String @id @default(cuid())
  maxFirstResponseMins  Int    @default(15)
  maxResolutionMins     Int    @default(1440)
  breachNotify          Boolean @default(true)
}

// ── CSAT Ratings ─────────────────────────────────────────────────────────────

model CSATRating {
  id             String       @id @default(cuid())
  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  rating         Int          // 1-5
  feedback       String?
  createdAt      DateTime     @default(now())
}

// ── Notification Preferences (Portal) ────────────────────────────────────────

model NotificationPreference {
  id          String  @id @default(cuid())
  clientId    String
  client      Client  @relation(fields: [clientId], references: [id])
  category    String  // "messages" | "invoices" | "projects" | "files" | "system"
  push        Boolean @default(true)
  email       Boolean @default(true)

  @@unique([clientId, category])
}

// ── Invoice Disputes (Portal) ────────────────────────────────────────────────

model InvoiceDispute {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  reason    String   @db.Text
  status    String   @default("open") // "open" | "reviewing" | "resolved"
  adminNote String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Client Team Members (Portal) ─────────────────────────────────────────────

model ClientTeamMember {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  email        String
  name         String?
  role         String   @default("viewer") // "viewer" | "admin"
  passwordHash String?
  invitedAt    DateTime @default(now())
  acceptedAt   DateTime?

  @@unique([clientId, email])
}
